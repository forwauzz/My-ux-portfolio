# Copy to .env.local for local dev. For production (e.g. Netlify), set these in the host's environment (e.g. Netlify UI).
# Firebase: get values from Firebase Console > Project settings
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# Storage bucket, e.g. ux-accelerator-console.firebasestorage.app (required for image uploads; set CORS per docs/STORAGE_CORS.md)
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ImgBB (free image hosting). Get key at https://api.imgbb.com/
IMGBB_API_KEY=
